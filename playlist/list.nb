  "]"}]], "Input",ExpressionUUID->"f4813f13-1719-4fa8-961a-00d6e1631178"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"imageList", "=", 
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"FileNames", "[", "]"}], ",", 
     RowBox[{
      RowBox[{"MemberQ", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<jpg\>\"", ",", "\"\<png\>\""}], "}"}], ",", 
        RowBox[{"FileExtension", "[", "#", "]"}]}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"process", "=", 
   RowBox[{"Function", "[", 
    RowBox[{"path", ",", 
     RowBox[{
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"FileBaseName", "[", "path", "]"}], "<>", "\"\<.webp\>\""}], 
        ",", 
        RowBox[{"Import", "@", "path"}], ",", 
        RowBox[{"CompressionLevel", "->", "0.5"}]}], "]"}], ";", 
      RowBox[{"DeleteFile", "[", "path", "]"}]}]}], "]"}]}], ";"}]}], "Input",
 GeneratedCell->False,
 CellAutoOverwrite->False,
 CellChangeTimes->{
